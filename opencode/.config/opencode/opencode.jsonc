{
  "$schema": "https://opencode.ai/config.json",
  "theme": "rosepine",
  "keybinds": {
    "command_list": "ctrl+l",
    "variant_cycle": "ctrl+o"
  },
  "lsp": {
    "rust_analyzer": {
      "command": ["rust-analyzer"],
      "extensions": [".rs"]
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{file:~/.secrets/context7-key}"
      },
      "enabled": true
    },
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp",
      "enabled": true
    },
    "xcode": {
      "type": "local",
      "command": ["xcrun", "mcpbridge"],
      "enabled": true
    },
    "paper": {
      "type": "remote",
      "url": "http://127.0.0.1:29979/mcp",
      "enabled": true
    }
  }
}
