#!/usr/bin/env bun
export * from "./gt-src/index.ts";

import { main } from "./gt-src/cli.ts";
import { GtError } from "./gt-src/errors.ts";

if (import.meta.main) {
  main().catch((error) => {
    if (error instanceof GtError) {
      if (error.message) {
        console.error(`gt: ${error.message}`);
      }
      process.exit(error.exitCode);
    }

    console.error(error);
    process.exit(1);
  });
}
