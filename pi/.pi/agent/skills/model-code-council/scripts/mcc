#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

REVIEW_ROOT="${MCC_REVIEW_ROOT:-$HOME/.local/share/pi/model-code-council}"
CLAUDE_BIN="${MCC_CLAUDE_BIN:-claude}"
OPUS_MODEL="${MCC_OPUS_MODEL:-opus}"
OPUS_EFFORT="${MCC_OPUS_EFFORT:-xhigh}"
DRIVER_MODEL="${MCC_DRIVER_MODEL_NAME:-GPT-5.5}"
REVIEWER_MODEL="${MCC_REVIEWER_MODEL_NAME:-Opus 4.7}"
DOCTOR_MODEL="${MCC_DOCTOR_MODEL:-$OPUS_MODEL}"
DOCTOR_EFFORT="${MCC_DOCTOR_EFFORT:-low}"

usage() {
  cat <<'EOF'
model-code-council helper

Usage:
  mcc start [--cwd DIR] [--request TEXT | --request-file FILE]
  mcc opus-initial [--bg|--background] <session-dir|latest>
  mcc opus-respond [--bg|--background] <session-dir|latest>
  mcc wait <session-dir|latest> [--timeout SEC]
  mcc cancel <session-dir|latest> [--run-id ID]
  mcc append-gpt <session-dir|latest> <item-id-or-file> [--position POS] [--status STATUS|keep] [--no-status] [--body-file FILE]
  mcc set-status <session-dir|latest> <item-id-or-file> <status>
  mcc resolve <session-dir|latest> <item-id-or-file> --status FINAL [--decision TEXT | --decision-file FILE] [--implementation TEXT] [--question TEXT]
  mcc status <session-dir|latest>
  mcc latest
  mcc doctor

Examples:
  MCC="$HOME/.pi/agent/skills/model-code-council/scripts/mcc"

  "$MCC" start --cwd /path/to/repo <<'REQ'
  Review the authentication refactor for correctness and maintainability.
  REQ

  # Recommended inside Pi: start Opus in the background, then wait/poll compact status.
  "$MCC" opus-initial --bg latest
  "$MCC" wait latest --timeout 1800
  "$MCC" status latest

  "$MCC" append-gpt latest O-001 --position accept-with-modification <<'EOF'
  Analysis:
  ...

  Proposed resolution:
  ...
  EOF

  # Avoid heredoc collisions by writing a body file first.
  "$MCC" append-gpt latest O-001 --position reject --body-file /tmp/gpt-response.md

Environment:
  MCC_REVIEW_ROOT           default: ~/.local/share/pi/model-code-council
  MCC_CLAUDE_BIN            default: claude
  MCC_OPUS_MODEL            default: opus
  MCC_OPUS_EFFORT           default: xhigh (Claude also supports max)
  MCC_DRIVER_MODEL_NAME     default: GPT-5.5
  MCC_REVIEWER_MODEL_NAME   default: Opus 4.7
  MCC_DOCTOR_MODEL          default: same as MCC_OPUS_MODEL
  MCC_DOCTOR_EFFORT         default: low
EOF
}

die() {
  echo "mcc: error: $*" >&2
  exit 1
}

slugify() {
  printf '%s' "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g'
}

latest_session() {
  [[ -d "$REVIEW_ROOT" ]] || die "review root does not exist: $REVIEW_ROOT"
  local latest
  latest="$(ls -td "$REVIEW_ROOT"/* 2>/dev/null | head -n 1 || true)"
  [[ -n "$latest" ]] || die "no review sessions found in $REVIEW_ROOT"
  printf '%s\n' "$latest"
}

resolve_session() {
  local session="${1:-}"
  [[ -n "$session" ]] || die "missing session directory"
  if [[ "$session" == "latest" ]]; then
    latest_session
  else
    [[ -d "$session" ]] || die "session directory not found: $session"
    printf '%s\n' "$session"
  fi
}

resolve_item() {
  local session="$1"
  local item="$2"

  if [[ -f "$item" ]]; then
    printf '%s\n' "$item"
    return
  fi

  if [[ -f "$session/items/$item" ]]; then
    printf '%s\n' "$session/items/$item"
    return
  fi

  local matches=()
  while IFS= read -r -d '' f; do
    matches+=("$f")
  done < <(find "$session/items" -maxdepth 1 -type f -name "$item*.md" -print0 2>/dev/null | sort -z)

  case "${#matches[@]}" in
    0) die "no item matched '$item' in $session/items" ;;
    1) printf '%s\n' "${matches[0]}" ;;
    *)
      echo "mcc: multiple items matched '$item':" >&2
      printf '  %s\n' "${matches[@]}" >&2
      exit 1
      ;;
  esac
}

valid_status() {
  case "$1" in
    OPEN|NEEDS_OPUS|NEEDS_GPT|NEEDS_TEST|AGREED_IMPLEMENT|AGREED_IMPLEMENT_MODIFIED|AGREED_REJECT|AGREED_DEFER|ESCALATED)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

valid_final_status() {
  case "$1" in
    AGREED_IMPLEMENT|AGREED_IMPLEMENT_MODIFIED|AGREED_REJECT|AGREED_DEFER|ESCALATED)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

next_for_status() {
  case "$1" in
    NEEDS_OPUS) printf '%s\n' "$REVIEWER_MODEL response" ;;
    NEEDS_GPT|OPEN) printf '%s\n' "$DRIVER_MODEL response" ;;
    NEEDS_TEST) printf '%s\n' "run verification" ;;
    AGREED_*|ESCALATED) printf '%s\n' "human" ;;
    *) printf '%s\n' "triage" ;;
  esac
}

is_final_status() {
  case "$1" in
    AGREED_*|ESCALATED) return 0 ;;
    *) return 1 ;;
  esac
}

read_request_from_args_or_stdin() {
  local request=""
  local request_file=""
  local args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --request)
        [[ $# -ge 2 ]] || die "--request requires text"
        request="$2"
        shift 2
        ;;
      --request-file)
        [[ $# -ge 2 ]] || die "--request-file requires a file"
        request_file="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        args+=("$1")
        shift
        ;;
    esac
  done

  if [[ -n "$request_file" ]]; then
    [[ -f "$request_file" ]] || die "request file not found: $request_file"
    request="$(cat "$request_file")"
  elif [[ -z "$request" && ${#args[@]} -gt 0 ]]; then
    request="${args[*]}"
  elif [[ -z "$request" && ! -t 0 ]]; then
    request="$(cat)"
  fi

  [[ -n "${request//[[:space:]]/}" ]] || die "empty review request; pass --request, --request-file, args, or stdin"
  printf '%s\n' "$request"
}

start_session() {
  local cwd_override=""
  local args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --cwd|--repo|--workdir)
        [[ $# -ge 2 ]] || die "$1 requires a directory"
        cwd_override="$2"
        shift 2
        ;;
      *)
        args+=("$1")
        shift
        ;;
    esac
  done

  local request
  request="$(read_request_from_args_or_stdin "${args[@]}")"

  local cwd repo_root repo_name slug stamp session created
  if [[ -n "$cwd_override" ]]; then
    [[ -d "$cwd_override" ]] || die "--cwd directory not found: $cwd_override"
    cwd="$(cd "$cwd_override" && pwd -P)"
  else
    cwd="$(pwd -P)"
  fi

  repo_root="$(git -C "$cwd" rev-parse --show-toplevel 2>/dev/null || printf '%s\n' "$cwd")"
  repo_name="$(basename "$repo_root")"
  slug="$(slugify "$repo_name")"
  [[ -n "$slug" ]] || slug="workspace"
  stamp="$(date +'%Y-%m-%d-%H%M%S')"
  created="$(date -Iseconds)"
  session="$REVIEW_ROOT/$stamp-$slug"

  mkdir -p "$session/items" "$session/logs" "$session/prompts"

  printf '%s\n' "$request" > "$session/request.md"
  printf '%s\n' "$cwd" > "$session/.cwd"
  printf '%s\n' "$repo_root" > "$session/.repo-root"
  printf '%s\n' "$DRIVER_MODEL" > "$session/.driver-model"
  printf '%s\n' "$REVIEWER_MODEL" > "$session/.reviewer-model"
  cp "$SKILL_DIR/prompts/constitution.md" "$session/prompts/constitution.md"

  cat > "$session/README.md" <<EOF
# Model Code Council

Created: $created
Status: IN_PROGRESS
Working directory: $cwd
Repository root: $repo_root
Driver: $DRIVER_MODEL via Pi
Reviewer: $REVIEWER_MODEL via Claude Code
Review folder: $session

## Human review request

$request

## Write boundaries

- $REVIEWER_MODEL may inspect the working directory and run tests/builds/checks.
- $REVIEWER_MODEL may create/edit files only inside this review folder.
- $REVIEWER_MODEL must not intentionally modify the codebase.
- $DRIVER_MODEL may append to council files during review.
- $DRIVER_MODEL edits code only after human approval.

## Main files

- \`council.md\`: item index and status
- \`findings.md\`: useful non-item observations
- \`items/\`: one file per review item
- \`logs/\`: command output and git status snapshots
- \`prompts/\`: prompts sent to Opus
EOF

  cat > "$session/findings.md" <<EOF
# Findings

Useful observations that do not merit a full review item go here.

If an observation requires action or a decision, create an item in \`items/\` instead.
EOF

  sync_council "$session"

  echo "Created model code council session:"
  echo "$session"
}

render_template() {
  local template_file="$1"
  local session="$2"
  local constitution_file="$session/prompts/constitution.md"
  [[ -f "$constitution_file" ]] || constitution_file="$SKILL_DIR/prompts/constitution.md"
  command -v python3 >/dev/null 2>&1 || die "python3 is required to render prompts safely"

  DRIVER_MODEL_RENDER="$DRIVER_MODEL" \
  REVIEWER_MODEL_RENDER="$REVIEWER_MODEL" \
  WORKING_DIR_RENDER="$(cat "$session/.cwd")" \
  REVIEW_DIR_RENDER="$session" \
  REQUEST_FILE_RENDER="$session/request.md" \
  CONSTITUTION_FILE_RENDER="$constitution_file" \
  python3 - "$template_file" <<'PY'
import os
import re
import sys
from pathlib import Path

template = Path(sys.argv[1]).read_text()
request = Path(os.environ["REQUEST_FILE_RENDER"]).read_text()
constitution = Path(os.environ["CONSTITUTION_FILE_RENDER"]).read_text()
replacements = {
    "DRIVER_MODEL": os.environ["DRIVER_MODEL_RENDER"],
    "REVIEWER_MODEL": os.environ["REVIEWER_MODEL_RENDER"],
    "WORKING_DIR": os.environ["WORKING_DIR_RENDER"],
    "REVIEW_DIR": os.environ["REVIEW_DIR_RENDER"],
    "REQUEST": request,
    "CONSTITUTION": constitution,
}
pattern = re.compile(r"\{\{(DRIVER_MODEL|REVIEWER_MODEL|WORKING_DIR|REVIEW_DIR|REQUEST|CONSTITUTION)\}\}")
sys.stdout.write(pattern.sub(lambda m: replacements[m.group(1)], template))
PY
}

snapshot_git_status() {
  local out="$1"
  local porcelain="$2"
  {
    echo "timestamp: $(date -Iseconds)"
    echo "cwd: $(pwd -P)"
    if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      echo
      echo "## git status --short --branch"
      git status --short --branch || true
      echo
      echo "## git diff --stat"
      git diff --stat || true
      git status --porcelain=v1 -z > "$porcelain" || true
    else
      echo
      echo "Not inside a git work tree."
      : > "$porcelain"
    fi
  } > "$out"
}

warn_if_status_changed() {
  local before_z="$1"
  local after_z="$2"
  local warning_file="$3"

  if ! cmp -s "$before_z" "$after_z"; then
    cat > "$warning_file" <<EOF
WARNING: git status changed while Opus was running.

This can happen if tests/builds generated artifacts, but it may also indicate an accidental codebase modification.
Inspect before proceeding.

Before snapshot: ${before_z%.porcelain.z}.txt
After snapshot:  ${after_z%.porcelain.z}.txt
EOF
    echo "mcc: warning: git status changed while Opus was running; see $warning_file" >&2
  fi
}

escape_table_cell() {
  printf '%s' "$1" | sed 's/|/\\|/g'
}

sync_council() {
  local session="$1"
  local tmp request cwd status overall all_final=1 any_items=0
  tmp="$(mktemp)"
  request="$(cat "$session/request.md" 2>/dev/null || true)"
  cwd="$(cat "$session/.cwd" 2>/dev/null || true)"

  shopt -s nullglob
  local files=("$session"/items/*.md)
  shopt -u nullglob

  if [[ ${#files[@]} -eq 0 ]]; then
    all_final=0
  fi

  for f in "${files[@]}"; do
    any_items=1
    status="$(awk -F': *' '/^Status:/ { print $2; exit }' "$f")"
    if ! is_final_status "$status"; then
      all_final=0
    fi
  done

  if [[ $any_items -eq 1 && $all_final -eq 1 ]]; then
    overall="READY_FOR_HUMAN_APPROVAL"
  else
    overall="IN_PROGRESS"
  fi

  {
    echo "# Council Status"
    echo
    echo "Status: $overall"
    echo "Working directory: $cwd"
    echo "Driver: $DRIVER_MODEL"
    echo "Reviewer: $REVIEWER_MODEL"
    echo
    echo "## Review request"
    echo
    printf '%s\n' "$request"
    echo
    echo "## Items"
    echo
    echo "| ID | Title | Severity | Status | Next |"
    echo "|----|-------|----------|--------|------|"

    local f raw id title severity next
    for f in "${files[@]}"; do
      raw="$(awk '/^# / { sub(/^# /, ""); print; exit }' "$f")"
      id="${raw%%:*}"
      title="${raw#*: }"
      [[ "$title" != "$raw" ]] || title="$raw"
      severity="$(awk -F': *' '/^Severity:/ { print $2; exit }' "$f")"
      status="$(awk -F': *' '/^Status:/ { print $2; exit }' "$f")"
      [[ -n "$severity" ]] || severity="?"
      [[ -n "$status" ]] || status="?"
      next="$(next_for_status "$status")"
      printf '| %s | %s | %s | %s | %s |\n' \
        "$(escape_table_cell "$id")" \
        "$(escape_table_cell "$title")" \
        "$(escape_table_cell "$severity")" \
        "$(escape_table_cell "$status")" \
        "$(escape_table_cell "$next")"
    done

    if [[ $any_items -eq 1 && $all_final -eq 1 ]]; then
      echo
      echo "All items are settled. Awaiting human approval before $DRIVER_MODEL implements."
    fi
  } > "$tmp"

  mv "$tmp" "$session/council.md"
}

write_run_meta() {
  local meta="$1"
  local run_id="$2"
  local phase="$3"
  local session="$4"
  local prompt="$5"
  local stdout="$6"
  local stderr="$7"
  local runner="$8"
  cat > "$meta" <<EOF
run_id: $run_id
phase: $phase
started: $(date -Iseconds)
session: $session
working_dir: $(cat "$session/.cwd")
model: $OPUS_MODEL
effort: $OPUS_EFFORT
prompt: $prompt
stdout: $stdout
stderr: $stderr
runner_log: $runner
EOF
}

run_opus_body() {
  local cwd="$1"
  local session="$2"
  local prompt="$3"
  local stdout="$4"
  local stderr="$5"
  local before="$6"
  local before_z="$7"
  local after="$8"
  local after_z="$9"
  local warning="${10}"
  local running="${11}"
  local exit_file="${12}"
  local done_file="${13}"
  local failed_file="${14}"

  cd "$cwd" || exit 97
  snapshot_git_status "$before" "$before_z"

  set +e
  "$CLAUDE_BIN" \
    --print \
    --model "$OPUS_MODEL" \
    --effort "$OPUS_EFFORT" \
    --dangerously-skip-permissions \
    --add-dir "$session" \
    < "$prompt" \
    > "$stdout" 2> "$stderr"
  local rc=$?
  set -e

  snapshot_git_status "$after" "$after_z"
  warn_if_status_changed "$before_z" "$after_z" "$warning"
  sync_council "$session" || true

  printf '%s\n' "$rc" > "$exit_file"
  rm -f "$running"
  if [[ $rc -eq 0 ]]; then
    date -Iseconds > "$done_file"
  else
    date -Iseconds > "$failed_file"
  fi
  exit "$rc"
}

run_opus() {
  local phase="$1"
  local session="$2"
  local template="$3"
  local background="${4:-0}"

  command -v "$CLAUDE_BIN" >/dev/null 2>&1 || die "Claude Code CLI not found: $CLAUDE_BIN"

  local cwd stamp run_id prompt stdout stderr runner before before_z after after_z warning meta running exit_file done_file failed_file cancelled_file rc pid
  cwd="$(cat "$session/.cwd")"
  [[ -d "$cwd" ]] || die "working directory no longer exists: $cwd"

  stamp="$(date +'%Y-%m-%d-%H%M%S')"
  run_id="$phase-$stamp"
  prompt="$session/prompts/$run_id.md"
  stdout="$session/logs/$run_id.stdout.md"
  stderr="$session/logs/$run_id.stderr.txt"
  runner="$session/logs/$run_id.runner.txt"
  before="$session/logs/$run_id.before-git-status.txt"
  before_z="$session/logs/$run_id.before-git-status.porcelain.z"
  after="$session/logs/$run_id.after-git-status.txt"
  after_z="$session/logs/$run_id.after-git-status.porcelain.z"
  warning="$session/logs/$run_id.WORKING_TREE_CHANGED.txt"
  meta="$session/logs/$run_id.meta"
  running="$session/logs/$run_id.running"
  exit_file="$session/logs/$run_id.exit-code"
  done_file="$session/logs/$run_id.done"
  failed_file="$session/logs/$run_id.failed"
  cancelled_file="$session/logs/$run_id.cancelled"

  render_template "$template" "$session" > "$prompt"
  write_run_meta "$meta" "$run_id" "$phase" "$session" "$prompt" "$stdout" "$stderr" "$runner"

  echo "Prepared $REVIEWER_MODEL ($OPUS_MODEL, effort=$OPUS_EFFORT) for phase '$phase'."
  echo "Session: $session"
  echo "Prompt:  $prompt"
  echo "Logs:    $session/logs/$run_id.*"

  if [[ "$background" == "1" ]]; then
    run_opus_body "$cwd" "$session" "$prompt" "$stdout" "$stderr" "$before" "$before_z" "$after" "$after_z" "$warning" "$running" "$exit_file" "$done_file" "$failed_file" > "$runner" 2>&1 &
    pid=$!
    if [[ ! -f "$done_file" && ! -f "$failed_file" && ! -f "$cancelled_file" ]]; then
      {
        echo "pid: $pid"
        echo "started: $(date -Iseconds)"
        echo "run_id: $run_id"
      } > "$running"
    fi
    disown "$pid" 2>/dev/null || true

    echo "Started in background with pid $pid."
    echo "Wait compactly with: $0 wait '$session'"
    echo "Poll compact status with: $0 status '$session'"
    return 0
  fi

  echo "Running in foreground. Opus stdout/stderr are captured to logs, not streamed into Pi context."
  set +e
  run_opus_body "$cwd" "$session" "$prompt" "$stdout" "$stderr" "$before" "$before_z" "$after" "$after_z" "$warning" "$running" "$exit_file" "$done_file" "$failed_file" > "$runner" 2>&1
  rc=$?
  set -e

  if [[ $rc -ne 0 ]]; then
    echo "mcc: Opus command failed with exit code $rc" >&2
    echo "stdout: $stdout" >&2
    echo "stderr: $stderr" >&2
    echo "runner: $runner" >&2
    exit "$rc"
  fi

  echo "Opus phase complete."
  echo "stdout: $stdout"
  echo "stderr: $stderr"
  echo "runner: $runner"
}

parse_run_command() {
  local phase="$1"
  local template="$2"
  shift 2
  local background=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --bg|--background)
        background=1
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        break
        ;;
    esac
  done

  local session
  session="$(resolve_session "${1:-}")"
  run_opus "$phase" "$session" "$template" "$background"
}

update_item_status() {
  local file="$1"
  local status="$2"
  local tmp
  tmp="$(mktemp)"
  awk -v st="$status" '
    BEGIN { done = 0 }
    /^Status:/ && done == 0 { print "Status: " st; done = 1; next }
    { print }
  ' "$file" > "$tmp"
  mv "$tmp" "$file"
}

append_gpt() {
  local session item position="" status="NEEDS_OPUS" body_file="" keep_status=0
  session="$(resolve_session "${1:-}")"
  shift || true
  [[ $# -ge 1 ]] || die "append-gpt requires an item id or file"
  item="$1"
  shift

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --position)
        [[ $# -ge 2 ]] || die "--position requires a value"
        position="$2"
        shift 2
        ;;
      --status)
        [[ $# -ge 2 ]] || die "--status requires a value"
        if [[ "$2" == "keep" ]]; then
          keep_status=1
          status=""
        else
          valid_status "$2" || die "invalid status: $2"
          status="$2"
          keep_status=0
        fi
        shift 2
        ;;
      --no-status)
        keep_status=1
        status=""
        shift
        ;;
      --body-file)
        [[ $# -ge 2 ]] || die "--body-file requires a file"
        body_file="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown append-gpt argument: $1"
        ;;
    esac
  done

  local file body turn_count turn_num stamp
  file="$(resolve_item "$session" "$item")"
  if [[ -n "$body_file" ]]; then
    [[ -f "$body_file" ]] || die "body file not found: $body_file"
    body="$(cat "$body_file")"
  else
    body="$(cat)"
  fi
  [[ -n "${body//[[:space:]]/}" ]] || die "append-gpt requires response text on stdin or --body-file"

  turn_count="$(grep -Fc -- "## $DRIVER_MODEL turn " "$file" 2>/dev/null || true)"
  turn_num=$((turn_count + 1))
  stamp="$(date +'%Y-%m-%d %H:%M')"

  {
    echo
    echo "## $DRIVER_MODEL turn $turn_num — $stamp"
    echo
    if [[ -n "$position" ]]; then
      echo "Position: $position"
      echo
    fi
    printf '%s\n' "$body"
  } >> "$file"

  if [[ $keep_status -eq 0 && -n "$status" ]]; then
    update_item_status "$file" "$status"
  fi
  sync_council "$session"

  echo "Appended $DRIVER_MODEL turn $turn_num to $file"
}

set_status_cmd() {
  local session item status file
  session="$(resolve_session "${1:-}")"
  item="${2:-}"
  status="${3:-}"
  [[ -n "$item" && -n "$status" ]] || die "set-status requires session, item, and status"
  valid_status "$status" || die "invalid status: $status"
  file="$(resolve_item "$session" "$item")"
  update_item_status "$file" "$status"
  sync_council "$session"
  echo "Set $(basename "$file") to $status"
}

resolve_cmd() {
  local session item file status="" decision="" decision_file="" implementation="" implementation_file="" question="" question_file=""
  session="$(resolve_session "${1:-}")"
  shift || true
  [[ $# -ge 1 ]] || die "resolve requires an item id or file"
  item="$1"
  shift

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --status)
        [[ $# -ge 2 ]] || die "--status requires a final status"
        status="$2"
        shift 2
        ;;
      --decision)
        [[ $# -ge 2 ]] || die "--decision requires text"
        decision="$2"
        shift 2
        ;;
      --decision-file)
        [[ $# -ge 2 ]] || die "--decision-file requires a file"
        decision_file="$2"
        shift 2
        ;;
      --implementation)
        [[ $# -ge 2 ]] || die "--implementation requires text"
        implementation="$2"
        shift 2
        ;;
      --implementation-file)
        [[ $# -ge 2 ]] || die "--implementation-file requires a file"
        implementation_file="$2"
        shift 2
        ;;
      --question)
        [[ $# -ge 2 ]] || die "--question requires text"
        question="$2"
        shift 2
        ;;
      --question-file)
        [[ $# -ge 2 ]] || die "--question-file requires a file"
        question_file="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown resolve argument: $1"
        ;;
    esac
  done

  [[ -n "$status" ]] || die "resolve requires --status FINAL"
  valid_final_status "$status" || die "resolve status must be final: $status"

  if [[ -n "$decision_file" ]]; then
    [[ -f "$decision_file" ]] || die "decision file not found: $decision_file"
    decision="$(cat "$decision_file")"
  elif [[ -z "$decision" && ! -t 0 ]]; then
    decision="$(cat)"
  fi
  if [[ -n "$implementation_file" ]]; then
    [[ -f "$implementation_file" ]] || die "implementation file not found: $implementation_file"
    implementation="$(cat "$implementation_file")"
  fi
  if [[ -n "$question_file" ]]; then
    [[ -f "$question_file" ]] || die "question file not found: $question_file"
    question="$(cat "$question_file")"
  fi

  file="$(resolve_item "$session" "$item")"
  update_item_status "$file" "$status"
  {
    echo
    echo "## Resolution — $(date +'%Y-%m-%d %H:%M')"
    echo
    echo "Status: $status"
    echo
    echo "Decision:"
    printf '%s\n' "${decision:-No additional decision text provided.}"
    echo
    echo "Implementation plan, if any:"
    printf '%s\n' "${implementation:-None recorded.}"
    echo
    echo "Open human question, if escalated:"
    printf '%s\n' "${question:-None.}"
  } >> "$file"
  sync_council "$session"
  echo "Resolved $(basename "$file") as $status"
}

meta_value() {
  local file="$1"
  local key="$2"
  awk -v k="$key" 'index($0, k ": ") == 1 { sub(k ": ", ""); print; exit }' "$file"
}

byte_count() {
  local file="$1"
  if [[ -f "$file" ]]; then
    wc -c < "$file" | tr -d '[:space:]'
  else
    printf '0'
  fi
}

latest_meta() {
  local session="$1"
  ls -t "$session"/logs/*.meta 2>/dev/null | head -n 1 || true
}

meta_for_run_id() {
  local session="$1"
  local run_id="$2"
  local meta="$session/logs/$run_id.meta"
  [[ -f "$meta" ]] || die "run id not found: $run_id"
  printf '%s\n' "$meta"
}

run_state_for_meta() {
  local meta="$1"
  local base="${meta%.meta}"
  local running="$base.running"
  local done="$base.done"
  local failed="$base.failed"
  local cancelled="$base.cancelled"
  local exit_file="$base.exit-code"
  local state="INCOMPLETE"
  local detail=""

  if [[ -f "$cancelled" ]]; then
    rm -f "$running"
    state="CANCELLED"
    detail="exit $(cat "$exit_file" 2>/dev/null || echo 130)"
  elif [[ -f "$failed" ]]; then
    rm -f "$running"
    state="FAILED"
    detail="exit $(cat "$exit_file" 2>/dev/null || echo '?')"
  elif [[ -f "$done" ]]; then
    rm -f "$running"
    state="DONE"
    detail="exit $(cat "$exit_file" 2>/dev/null || echo 0)"
  elif [[ -f "$running" ]]; then
    local pid
    pid="$(awk -F': *' '/^pid:/ { print $2; exit }' "$running" 2>/dev/null || true)"
    if [[ -n "$pid" && "$pid" != "pending" ]] && kill -0 "$pid" 2>/dev/null; then
      state="RUNNING"
      detail="pid $pid"
    elif [[ -z "$pid" || "$pid" == "pending" ]]; then
      state="STALE-RUNNING"
      detail="pid was never recorded"
    else
      state="STALE-RUNNING"
      detail="pid $pid not active"
    fi
  fi

  printf '%s|%s\n' "$state" "$detail"
}

show_runs() {
  local session="$1"
  shopt -s nullglob
  local metas=("$session"/logs/*.meta)
  shopt -u nullglob

  if [[ ${#metas[@]} -eq 0 ]]; then
    echo "Latest Opus run: none"
    return
  fi

  IFS=$'\n' read -r -d '' -a metas < <(printf '%s\n' "${metas[@]}" | sort -r && printf '\0')

  echo "Latest Opus runs:"
  local count=0 meta run_id phase started state_detail state detail stdout stderr warning
  for meta in "${metas[@]}"; do
    [[ $count -lt 3 ]] || break
    run_id="$(meta_value "$meta" run_id)"
    phase="$(meta_value "$meta" phase)"
    started="$(meta_value "$meta" started)"
    stdout="$(meta_value "$meta" stdout)"
    stderr="$(meta_value "$meta" stderr)"
    state_detail="$(run_state_for_meta "$meta")"
    state="${state_detail%%|*}"
    detail="${state_detail#*|}"
    warning="${meta%.meta}.WORKING_TREE_CHANGED.txt"
    printf '  %s  %s  %s  %s\n' "$state" "$phase" "$started" "$detail"
    printf '    stdout: %s (%s bytes)\n' "$stdout" "$(byte_count "$stdout")"
    if [[ -s "$stderr" ]]; then
      printf '    stderr: %s (%s bytes)\n' "$stderr" "$(byte_count "$stderr")"
    fi
    if [[ -f "$warning" ]]; then
      printf '    warning: %s\n' "$warning"
    fi
    count=$((count + 1))
  done
}

latest_run_state() {
  local session="$1"
  local meta
  meta="$(latest_meta "$session")"
  [[ -n "$meta" ]] || return 1
  run_state_for_meta "$meta"
}

show_status() {
  local session="$1"
  shopt -s nullglob
  local files=("$session"/items/*.md)
  shopt -u nullglob

  echo "Session: $session"
  show_runs "$session"

  local state_detail=""
  state_detail="$(latest_run_state "$session" 2>/dev/null || true)"
  if [[ "${state_detail%%|*}" == "RUNNING" ]]; then
    echo "Note: latest Opus run is still RUNNING; item files may be partial until it reaches DONE/FAILED/CANCELLED."
  fi
  echo

  if [[ ${#files[@]} -eq 0 ]]; then
    echo "Items: none yet"
    return
  fi

  printf '%-8s %-10s %-28s %s\n' "ID" "Severity" "Status" "Title"
  printf '%-8s %-10s %-28s %s\n' "--------" "----------" "----------------------------" "-----"

  local f title id status severity
  for f in "${files[@]}"; do
    title="$(awk '/^# / { sub(/^# /, ""); print; exit }' "$f")"
    id="${title%%:*}"
    status="$(awk -F': *' '/^Status:/ { print $2; exit }' "$f")"
    severity="$(awk -F': *' '/^Severity:/ { print $2; exit }' "$f")"
    [[ -n "$status" ]] || status="?"
    [[ -n "$severity" ]] || severity="?"
    printf '%-8s %-10s %-28s %s\n' "$id" "$severity" "$status" "$title"
  done
}

wait_cmd() {
  local session timeout="" interval=5
  session="$(resolve_session "${1:-}")"
  shift || true
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --timeout)
        [[ $# -ge 2 ]] || die "--timeout requires seconds"
        timeout="$2"
        shift 2
        ;;
      --interval)
        [[ $# -ge 2 ]] || die "--interval requires seconds"
        interval="$2"
        shift 2
        ;;
      *)
        die "unknown wait argument: $1"
        ;;
    esac
  done

  local meta start now state_detail state detail run_id phase
  meta="$(latest_meta "$session")"
  [[ -n "$meta" ]] || die "no Opus runs found in $session"
  run_id="$(meta_value "$meta" run_id)"
  phase="$(meta_value "$meta" phase)"
  start="$(date +%s)"

  while true; do
    state_detail="$(run_state_for_meta "$meta")"
    state="${state_detail%%|*}"
    detail="${state_detail#*|}"
    case "$state" in
      DONE)
        echo "DONE phase=$phase run_id=$run_id $detail"
        return 0
        ;;
      FAILED)
        echo "FAILED phase=$phase run_id=$run_id $detail"
        return 1
        ;;
      CANCELLED)
        echo "CANCELLED phase=$phase run_id=$run_id $detail"
        return 130
        ;;
      STALE-RUNNING|INCOMPLETE)
        echo "$state phase=$phase run_id=$run_id $detail"
        return 1
        ;;
    esac

    if [[ -n "$timeout" ]]; then
      now="$(date +%s)"
      if (( now - start >= timeout )); then
        echo "TIMEOUT phase=$phase run_id=$run_id after=${timeout}s"
        return 124
      fi
    fi
    sleep "$interval"
  done
}

collect_descendants() {
  local pid="$1"
  local child
  for child in $(pgrep -P "$pid" 2>/dev/null || true); do
    collect_descendants "$child"
    printf '%s\n' "$child"
  done
}

cancel_cmd() {
  local session run_id="" meta base running pid pids=()
  session="$(resolve_session "${1:-}")"
  shift || true
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --run-id)
        [[ $# -ge 2 ]] || die "--run-id requires an id"
        run_id="$2"
        shift 2
        ;;
      *)
        die "unknown cancel argument: $1"
        ;;
    esac
  done

  if [[ -n "$run_id" ]]; then
    meta="$(meta_for_run_id "$session" "$run_id")"
  else
    meta="$(latest_meta "$session")"
    [[ -n "$meta" ]] || die "no Opus runs found in $session"
  fi

  base="${meta%.meta}"
  running="$base.running"
  pid="$(awk -F': *' '/^pid:/ { print $2; exit }' "$running" 2>/dev/null || true)"
  [[ -n "$pid" && "$pid" != "pending" ]] || die "no active pid recorded for $(basename "$base")"

  while IFS= read -r child; do
    [[ -n "$child" ]] && pids+=("$child")
  done < <(collect_descendants "$pid")
  pids+=("$pid")

  kill -TERM "${pids[@]}" 2>/dev/null || true
  sleep 2
  local still=()
  local p
  for p in "${pids[@]}"; do
    if kill -0 "$p" 2>/dev/null; then
      still+=("$p")
    fi
  done
  if [[ ${#still[@]} -gt 0 ]]; then
    kill -KILL "${still[@]}" 2>/dev/null || true
  fi

  printf '%s\n' 130 > "$base.exit-code"
  date -Iseconds > "$base.cancelled"
  rm -f "$running"
  echo "Cancelled run $(basename "$base")"
}

doctor() {
  command -v "$CLAUDE_BIN" >/dev/null 2>&1 || die "Claude Code CLI not found: $CLAUDE_BIN"

  local tmp prompt stdout stderr rc cwd expected
  tmp="$(mktemp -d)"
  prompt="$tmp/doctor-prompt.md"
  stdout="$tmp/stdout.md"
  stderr="$tmp/stderr.txt"
  expected="$tmp/doctor-ok.txt"
  cwd="$(pwd -P)"

  cat > "$prompt" <<EOF
You are testing the Model Code Council Claude Code invocation.

Working directory: $cwd
Allowed write directory: $tmp

Create exactly this file with the text ok:

$expected

Do not modify anything outside the allowed write directory. Then print one short sentence and exit.
EOF

  echo "Doctor: Claude binary: $(command -v "$CLAUDE_BIN")"
  echo "Doctor: model=$DOCTOR_MODEL effort=$DOCTOR_EFFORT"
  echo "Doctor: temp dir=$tmp"

  set +e
  (
    cd "$cwd" && "$CLAUDE_BIN" \
      --print \
      --model "$DOCTOR_MODEL" \
      --effort "$DOCTOR_EFFORT" \
      --dangerously-skip-permissions \
      --add-dir "$tmp" \
      < "$prompt" \
      > "$stdout" 2> "$stderr"
  )
  rc=$?
  set -e

  if [[ $rc -ne 0 ]]; then
    echo "Doctor: FAILED (claude exit $rc)" >&2
    echo "stdout: $stdout" >&2
    echo "stderr: $stderr" >&2
    exit "$rc"
  fi

  if [[ ! -f "$expected" ]]; then
    echo "Doctor: FAILED (Claude ran but did not create expected file)" >&2
    echo "stdout: $stdout" >&2
    echo "stderr: $stderr" >&2
    exit 1
  fi

  rm -rf "$tmp"
  echo "Doctor: OK (temp dir cleaned)"
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  start)
    start_session "$@"
    ;;
  opus-initial)
    parse_run_command "opus-initial" "$SKILL_DIR/prompts/opus-initial-review.md" "$@"
    ;;
  opus-respond)
    parse_run_command "opus-respond" "$SKILL_DIR/prompts/opus-respond.md" "$@"
    ;;
  wait)
    wait_cmd "$@"
    ;;
  cancel)
    cancel_cmd "$@"
    ;;
  append-gpt)
    append_gpt "$@"
    ;;
  set-status)
    set_status_cmd "$@"
    ;;
  resolve)
    resolve_cmd "$@"
    ;;
  status)
    session="$(resolve_session "${1:-}")"
    show_status "$session"
    ;;
  latest)
    latest_session
    ;;
  doctor)
    doctor
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage >&2
    die "unknown command: $cmd"
    ;;
esac
